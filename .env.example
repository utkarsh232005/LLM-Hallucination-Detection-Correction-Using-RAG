# Required API keys
SERPAPI_API_KEY=your_serpapi_key_here
PINECONE_API_KEY=your_pinecone_key_here

# Ollama service URL
OLLAMA_BASE_URL=http://ollama:11434

# Pinecone index name
INDEX_NAME=rag-embedds

# Optional model overrides
LLM_MODEL=smollm2:360m
RAG_LLM_MODEL=llama3.2:1b
EMBEDDINGS_MODEL=nomic-embed-text
LLM_NUM_PREDICT=128
RAG_NUM_PREDICT=192
LLM_NUM_CTX=2048
RAG_NUM_CTX=3072
RAG_CONTEXT_CHAR_LIMIT=3000
RETRIEVAL_K=8
HALLUCINATION_MODEL_ID=Shreyash03Chimote/Hallucination_Detection
HF_API_TOKEN=your_huggingface_token_if_needed
HF_TOKEN=your_huggingface_token_if_needed
HF_INFERENCE_TIMEOUT_SEC=30

# Backend host/port
HOST=0.0.0.0
PORT=8080
